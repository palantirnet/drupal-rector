{
    "name": "palantirnet/drupal-rector",
    "description": "Instant fixes for your Drupal code by using Rector.",
    "type": "library",
    "keywords": [
        "code style",
        "rector",
        "drupal",
        "ast"
    ],
    "require": {
        "rector/rector": "^2",
        "webflo/drupal-finder": "^1.2"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Dezső Biczó",
            "email": "mxr576@gmail.com"
        },
        {
            "name": "Ofer Shaal",
            "email": "shaal@palantir.net"
        },
        {
            "name": "Daniel Montgomery",
            "email": "montgomery@palantir.net"
        },
        {
            "name": "Matt Glaman",
            "email": "nmd.matt@gmail.com"
        },
        {
            "name": "Björn Brala",
            "email": "drupal@bjorn.dev"
        },
        {
            "name": "Ken Rickard",
            "email": "agentrickard@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "DrupalRector\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DrupalRector\\Tests\\": "tests/src"
        },
        "classmap": [
            "stubs"
        ],
        "exclude-from-classmap": [
            "**/fixture/**",
            "**/fixture-*/**",
            "**/Fixture/**"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "update-with-dependencies": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "rector/extension-installer": true,
            "cweagans/composer-patches": true
        }
    },
    "replace": {
        "palantirnet/drupal8-rector": "*",
        "drupal8-rector/drupal8-rector": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "enable-patching": true
    },
    "require-dev": {
        "php": "^8.2",
        "cweagans/composer-patches": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95.1",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.54",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpunit/phpunit": "^12.5.24",
        "symfony/yaml": "^5 || ^6 || ^7.4.8",
        "symplify/vendor-patches": "^12.0.6"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "check-style": "vendor/bin/php-cs-fixer check",
        "fix-style": "vendor/bin/php-cs-fixer fix"
    }
}
